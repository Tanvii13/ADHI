{
  "version": 2,
  "builds": [
  { "src": "app.py", "use": "@vercel/python" },
  { "src": "build/web/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/(.*)",
      "dest": "build/web/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "build/web/index.html"
    }
  ]
}
